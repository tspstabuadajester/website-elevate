        "completionPolicy": {
            "heading": {
                "type": "string",
                "value": "Important: Form Completion Policy & Associated Fees"
            },
            "intro": {
                "type": "richtext",
                "value": "To ensure you receive the highest quality care, all new patient intake forms must be completed through your TherapyNotes Patient Portal at least 24 hours prior to your scheduled appointment."
            },
            "items": {
                "type": "array",
                "value": [
                    {
                        "type": "object",
                        "value": {
                            "label": {
                                "type": "string",
                                "value": "Why this matters"
                            },
                            "text": {
                                "type": "richtext",
                                "value": "Your clinician thoroughly reviews your history, symptoms, and medical background before your session starts, allowing us to spend every minute of your appointment focusing entirely on you or your child."
                            }
                        }
                    },
                    {
                        "type": "object",
                        "value": {
                            "label": {
                                "type": "string",
                                "value": "Delayed Start Time"
                            },
                            "text": {
                                "type": "richtext",
                                "value": "If your paperwork is not completed 24 hours in advance, we may need to use a portion of your scheduled session time to complete it, reducing your face-to-face time with the clinician."
                            }
                        }
                    },
                    {
                        "type": "object",
                        "value": {
                            "label": {
                                "type": "string",
                                "value": "Rescheduling & Cancellation Fees"
                            },
                            "text": {
                                "type": "richtext",
                                "value": "If forms are incomplete by the time of your appointment, we reserve the right to reschedule your visit to a later date. Please note that our standard late cancellation/no-show fee of $75.00 will apply, as that time slot was reserved exclusively for you."
                            }
                        }
                    }
                ]
            }
        }
    },
    "practicePolicies": {
        "heading": {
            "type": "string",
            "value": "Practice Policies"
        },
        "intro": {
            "type": "richtext",
            "value": "At Elevate Mental Health and Wellness, our focus is on providing evidence-based psychiatric evaluation, medication management, and supportive psychotherapy. To ensure safe and effective care, please review the following practice policies:"
        },
        "items": {
            "type": "array",
            "value": [
                {
                    "type": "object",
                    "value": {
                        "title": {
                            "type": "string",
                            "value": "Disability Documentation"
                        },
                        "text": {
                            "type": "richtext",
                            "value": "Elevate Mental Health and Wellness does not certify disability or determine eligibility for disability benefits. Our role is to provide psychiatric evaluation and treatment. Requests for disability-related paperwork are reviewed on a case-by-case basis and are not guaranteed."
                        }
                    }
                },
                {
                    "type": "object",
                    "value": {
                        "title": {
                            "type": "string",
                            "value": "Benzodiazepine Prescribing"
                        },
                        "text": {
                            "type": "richtext",
                            "value": "Elevate Mental Health and Wellness follows current evidence-based guidelines regarding benzodiazepine medications (such as Xanax®, Ativan®, Klonopin®, and Valium®). Due to the risks of dependence, tolerance, cognitive impairment, and withdrawal, benzodiazepines are generally prescribed only for short-term or limited use when clinically appropriate. Long-term benzodiazepine therapy is not routinely provided by this practice. Patients already on chronic benzodiazepines from another provider must agree to a formal tapering plan under our care."
                        }
                    }
                },
                {
                    "type": "object",
                    "value": {
                        "title": {
                            "type": "string",
                            "value": "Stimulant Prescribing"
                        },
                        "text": {
                            "type": "richtext",
                            "value": "Stimulant medications used to treat ADHD (such as Adderall®, Vyvanse®, Concerta®, and Ritalin®) are prescribed only when clinically appropriate following a comprehensive evaluation. As controlled substances, they require strict monitoring, including regular follow-ups, vital sign checks, and possible random or scheduled urine drug screenings. Early refills, replacements for lost medications, or dose changes without an appointment may be declined. Our goal is to ensure the safe, effective, and responsible use of stimulant medications while providing individualized ADHD treatment."
                        }
                    }
                },
                {
                    "type": "object",
                    "value": {
                        "title": {
                            "type": "string",
                            "value": "A Teaching and Learning Environment"
                        },
                        "text": {
                            "type": "richtext",
                            "value": "Elevate Mental Health and Wellness is proud to support the education and training of future healthcare professionals. As a teaching clinic, healthcare trainees may participate in your care under the supervision of a licensed provider. Students are bound by strict confidentiality rules. You will be informed of their involvement and may decline participation at any time without affecting your care."
                        }
                    }
                }
            ]
        }
    },
