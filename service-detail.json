    "pageHero": {
        "heading": {
            "type": "string",
            "value": "New Patients"
        },
        "intro": {
            "type": "richtext",
            "value": "Everything you need to know before your first visit, from what to expect in care to completing your intake forms."
        }
    },
    "whatToExpect": {
        "heading": {
            "type": "string",
            "value": "What to Expect"
        },
        "intro": {
            "type": "richtext",
            "value": "Starting psychiatric care can feel like a major step, and it is completely normal to have questions about what your experience will look like. At Elevate Mental Health and Wellness, we aim to make your journey as transparent, comfortable, and predictable as possible."
        },
        "steps": {
            "type": "array",
            "value": [
                {
                    "type": "object",
                    "value": {
                        "number": {
                            "type": "string",
                            "value": "1"
                        },
                        "title": {
                            "type": "string",
                            "value": "Your Initial Psychiatric Evaluation"
                        },
                        "lead": {
                            "type": "richtext",
                            "value": "Your first appointment is a dedicated time for us to get to know you or your child. This comprehensive session typically lasts 60 to 90 minutes."
                        },
                        "whatWeDo": {
                            "type": "richtext",
                            "value": "We will discuss your current concerns, medical history, lifestyle, and past treatment experiences. For children and adolescents, this process heavily involves parents or guardians to ensure a complete picture."
                        },
                        "outcome": {
                            "type": "richtext",
                            "value": "We don't just hand you a prescription. By the end of this visit, we will share our clinical impressions, discuss potential diagnoses, and collaboratively build a personalized treatment plan that aligns with your goals."
                        }
                    }
                },
                {
                    "type": "object",
                    "value": {
                        "number": {
                            "type": "string",
                            "value": "2"
                        },
                        "title": {
                            "type": "string",
                            "value": "Follow-Up Appointments & Medication Management"
                        },
                        "lead": {
                            "type": "richtext",
                            "value": "If your treatment plan includes medication or integrated supportive therapy, we will schedule regular follow-up visits. These appointments are usually 25 to 50 minutes depending on your specific needs."
                        },
                        "whatWeDo": {
                            "type": "richtext",
                            "value": "We monitor how well the medication is working, manage any side effects, and adjust dosages as needed. We also use this time to practice coping strategies, provide psychoeducation, and check in on your overall well-being."
                        },
                        "frequency": {
                            "type": "richtext",
                            "value": "Initially, follow-up appointments are scheduled every 4 weeks to closely monitor your progress. Once your symptoms are stable and you are feeling well, appointments are typically spaced out to every 8 to 12 weeks."
                        }
                    }
                }
            ]
        },
        "privacyNote": {
            "type": "richtext",
            "value": "A Note on Privacy & Comfort: All sessions are entirely confidential and conducted in a warm, non-judgmental space whether you are seeing us in person or via our secure telehealth platform."
        }
    },
    "patientForms": {
        "heading": {
            "type": "string",
            "value": "Patient Forms"
        },
        "intro": {
            "type": "richtext",
            "value": "To maximize your time with your clinician during your first visit, we request that all new patients complete their intake paperwork prior to the scheduled appointment."
        },
        "ehr": {
            "heading": {
                "type": "string",
                "value": "Our Secure Electronic Health Record (EHR) Partner"
            },
            "paragraphs": {
                "type": "array",
                "value": [
                    {
                        "type": "richtext",
                        "value": "At Elevate Mental Health and Wellness, your privacy and data security are our top priorities. We partner with TherapyNotes, a leading, fully HIPAA-compliant electronic medical records platform. This ensures that your personal information, medical history, and clinical notes are encrypted and securely stored using the highest industry standards."
                    }
                ]
            }
        },
        "gettingForms": {
            "heading": {
                "type": "string",
                "value": "Getting Your Forms"
            },
            "text": {
                "type": "richtext",
                "value": "Once your initial appointment is booked, you will receive an automated email invitation to activate your secure account on our TherapyNotes Patient Portal. All required intake forms can be filled out, signed, and submitted electronically right from your computer, tablet, or smartphone."
            }
        },
        "formsList": {
            "heading": {
                "type": "string",
                "value": "Forms you will complete in the portal include:"
            },
            "items": {
                "type": "array",
                "value": [
                    {
                        "type": "object",
                        "value": {
                            "label": {
                                "type": "string",
                                "value": "New Patient Intake Questionnaire"
                            },
                            "detail": {
                                "type": "richtext",
                                "value": "Helps us understand your medical, developmental, and psychiatric history."
                            }
                        }
                    },
                    {
                        "type": "object",
                        "value": {
                            "label": {
                                "type": "string",
                                "value": "Practice Policies & Consent to Treatment"
                            },
                            "detail": {
                                "type": "richtext",
                                "value": "Outlines our scheduling, cancellation, and communication policies."
                            }
                        }
                    },
                    {
                        "type": "object",
                        "value": {
                            "label": {
                                "type": "string",
                                "value": "HIPAA Privacy Notice"
                            },
                            "detail": {
                                "type": "richtext",
                                "value": "Details how we protect your confidential medical information."
                            }
                        }
                    },
                    {
                        "type": "object",
                        "value": {
                            "label": {
                                "type": "string",
                                "value": "Billing & Insurance Authorization"
                            },
                            "detail": {
                                "type": "richtext",
                                "value": "Securely stores your payment method for copays or self-pay fees."
                            }
                        }
                    },
                    {
                        "type": "object",
                        "value": {
                            "label": {
                                "type": "string",
                                "value": "Student Observation & Participation Disclosure"
                            },
                            "detail": {
                                "type": "richtext",
                                "value": "Allows you to indicate your preference regarding having closely supervised psychiatric students or residents observe or participate in your care."
                            }
                        }
                    },
                    {
                        "type": "object",
                        "value": {
                            "label": {
                                "type": "string",
                                "value": "AI Scribe Documentation Consent"
                            },
                            "detail": {
                                "type": "richtext",
                                "value": "Allows you to opt in or out of our secure, HIPAA-compliant AI audio transcription tool used to assist your clinician with session note-taking."
                            }
                        }
                    }
                ]
            }
        },
