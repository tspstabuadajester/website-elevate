        "outOfNetwork": {
            "heading": {
                "type": "string",
                "value": "Out-of-Network & Self-Pay Options"
            },
            "paragraphs": {
                "type": "array",
                "value": [
                    {
                        "type": "richtext",
                        "value": "If we are not in-network with your insurance provider, or if you prefer not to use insurance, we offer standard self-pay rates."
                    },
                    {
                        "type": "richtext",
                        "value": "We can provide you with a Superbill (an itemized medical receipt) that you can submit to your insurance company for potential out-of-network reimbursement."
                    }
                ]
            },
            "note": {
                "type": "richtext",
                "value": "Please note: We do not guarantee reimbursement, as this depends entirely on your specific insurance plan."
            }
        },
