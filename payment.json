            },
            "intro": {
                "type": "richtext",
                "value": "We partner with a variety of commercial insurance plans to help keep your care accessible."
            },
            "inNetwork": {
                "label": {
                    "type": "string",
                    "value": "In-Network Plans"
                },
                "text": {
                    "type": "richtext",
                    "value": "We currently accept Anthem, Aetna, Cigna, UnitedHealthcare/Optum, Magellan, and Medicare."
                }
            },
            "comingSoon": {
                "label": {
                    "type": "string",
                    "value": "Other Major Insurances Coming Soon"
                },
                "text": {
                    "type": "richtext",
                    "value": "We are actively in the process of credentialing with additional major insurance panels. If you do not see your provider listed yet, please check back frequently or reach out to our office to see where we are in the approval process."
                }
            },
            "responsibility": {
                "label": {
                    "type": "string",
                    "value": "Your Responsibility"
                },
                "text": {
                    "type": "richtext",
                    "value": "Copays, deductibles, and co-insurance are due at the time of service. Because health insurance policies vary widely, we highly recommend calling the number on the back of your insurance card before your first visit to confirm your specific behavioral health benefits."
                }
            }
        },
