    "pageHero": {
        "heading": {
            "type": "string",
            "value": "About Us"
        },
        "intro": {
            "type": "richtext",
            "value": "Welcome to Elevate Mental Health and Wellness. We provide compassionate, evidence-based psychiatric care for children, adolescents, adults, and families."
        },
        "paragraphs": {
            "type": "array",
            "value": [
                {
                    "type": "richtext",
                    "value": "We understand that your mental health is a deeply personal, integral part of your overall well-being. Elevate was born out of a simple promise: to provide psychiatric care that is highly personalized, deeply collaborative, culturally sensitive, and entirely free of judgment. We honor your unique background, identity, and lived experiences. By combining clinical excellence with active behavioral management and tailored support, we walk alongside you to navigate life's challenges, unearth your innate resilience, and help your entire family truly thrive."
                }
            ]
        },
        "gallery": {
            "type": "array",
            "value": []
        }
    },
    "mission": {
        "heading": {
            "type": "string",
            "value": "Our Mission"
        },
        "columns": {
            "type": "array",
            "value": [
                {
                    "type": "richtext",
                    "value": "Our mission is to provide comprehensive, high-quality, and evidence-based psychiatric care that empowers individuals and families on their journey toward mental wellness. While we safely and skillfully manage symptoms through thoughtful medication management, we are fierce advocates of behavioral therapy and hands-on guidance."
                },
                {
                    "type": "richtext",
                    "value": "We believe that the best outcomes are achieved together. True, lasting success relies on a strong team approach, whether that means partnering with adults to take charge of their wellness, collaborating with loved ones and care systems for older adults, or equipping parents with the practical tools and guidance needed to support their child's growth."
                }
            ]
        }
    },
