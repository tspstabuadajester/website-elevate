        "quoteCard": {
            "text": {
                "type": "richtext",
                "value": "Making an impact, together"
            },
            "attribution": {
                "type": "string",
                "value": "Rohzan G. Altre, PMHNP"
            }
        },
        "heading": {
            "type": "string",
            "value": "Care that meets you where you are."
        },
        "paragraph": {
            "type": "richtext",
            "value": "Rohzan G. Altre is a board-certified psychiatric nurse practitioner licensed in California and Nevada. She works with children, teens, and adults facing ADHD, anxiety, depression, bipolar disorder, PTSD, and autism-related behavioral challenges."
        },
        "blockquote": {
            "type": "richtext",
            "value": "I believe people do best when they feel safe enough to be honest about what they are going through. My job is to listen closely, explain your options clearly, and help you find a path that actually works for your life."
        }
    },
