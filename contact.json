    "crisisPolicy": {
        "heading": {
            "type": "string",
            "value": "Crisis Policy & Immediate Support"
        },
        "paragraphs": {
            "type": "array",
            "value": [
                {
                    "type": "richtext",
                    "value": "Elevate Mental Health and Wellness provides scheduled psychiatric care and outpatient treatment. We do not provide 24/7 crisis management, immediate emergency services, or walk-in psychiatric care."
                },
                {
                    "type": "richtext",
                    "value": "If you or a loved one is experiencing a life-threatening medical emergency, a severe mental health crisis, or is in imminent danger of hurting themselves or others, please do not wait for an office reply. Seek help immediately."
                }
            ]
        },
        "resourcesHeading": {
            "type": "string",
            "value": "Where to Get Immediate Help (Available 24/7)"
        },
        "resources": {
            "type": "array",
            "value": [
                {
                    "type": "object",
                    "value": {
                        "label": {
                            "type": "string",
                            "value": "Call or Text 988"
                        },
                        "detail": {
                            "type": "richtext",
                            "value": "The 988 Suicide & Crisis Lifeline provides free, confidential, 24/7 support for anyone experiencing mental health-related distress or a suicidal crisis."
                        }
                    }
                },
                {
                    "type": "object",
                    "value": {
                        "label": {
                            "type": "string",
                            "value": "Text HOME to 741741"
                        },
                        "detail": {
                            "type": "richtext",
                            "value": "Connect with the Crisis Text Line to chat text-based with a trained crisis counselor 24/7."
                        }
                    }
                },
                {
                    "type": "object",
                    "value": {
                        "label": {
                            "type": "string",
                            "value": "Call 911"
                        },
                        "detail": {
                            "type": "richtext",
                            "value": "For immediate physical safety emergencies, call 911 or go to your nearest Hospital Emergency Room."
                        }
                    }
                },
                {
                    "type": "object",
                    "value": {
                        "label": {
                            "type": "string",
                            "value": "Veterans Crisis Line"
                        },
                        "detail": {
                            "type": "richtext",
                            "value": "Dial 988, then press 1, or text 838255 for dedicated veteran support."
                        }
                    }
                },
                {
                    "type": "object",
                    "value": {
                        "label": {
                            "type": "string",
                            "value": "The Trevor Project (for LGBTQ+ youth)"
                        },
                        "detail": {
                            "type": "richtext",
                            "value": "Call 1-866-488-7386 or text START to 678-678."
                        }
                    }
                }
            ]
        },
        "patientsNote": {
            "type": "richtext",
            "value": "For Existing Patients: If you are experiencing a non-emergency clinical issue or a medication side effect outside of office hours, please leave a secure message through your TherapyNotes Patient Portal or call our office line. We will review your message during normal business hours on our next operational day."
        }
    },
